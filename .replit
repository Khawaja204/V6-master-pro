run = "bash bootstrap.sh"
modules = ["python-3.11"]

[nix]
channel = "stable-23_11"
packages = ["python311", "python311Packages.fastapi", "python311Packages.python-dotenv", "python311Packages.requests", "python311Packages.uvicorn"]

[[ports]]
localPort = 8080
externalPort = 80

[deployment]
deploymentTarget = "cloudrun"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash bootstrap.sh"
waitForPort = 8080

[workflows.workflow.metadata]
outputType = "webview"
